generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Currency {
  KZT
  RUB
  KGS
  UZS
  USD
  EUR
}

enum UnitType {
  WEIGHT
  VOLUME
  PIECE
  LENGTH
  CUSTOM
}

enum SubscriptionType {
  FREE
  PREMIUM
}

model User {
  id                String        @id @default(uuid()) @db.Uuid
  username          String        @unique
  email             String        @unique
  password          String
  name              String
  currency          Currency      @default(KZT)
  subscriptionType SubscriptionType @default(FREE)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  ingredients       Ingredient[]
  recipes           Recipe[]
  units             Unit[]
  expenses          Expense[]
  expenseItems      ExpenseItem[]
  salesRecords      SalesRecord[]
}

model Unit {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String?   @db.Uuid
  name              String
  nameKZ            String?
  nameEN            String?
  shortName         String    @unique
  baseUnitId        String?   @default("")
  conversionFactor  Float?    @default(1)
  type              UnitType
  isSystem          Boolean   @default(false)
  user              User?     @relation(fields: [userId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  ingredients       Ingredient[]
  recipeIngredients RecipeIngredient[]
  expenseItems      ExpenseItem[]
}

model Ingredient {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  name              String
  unitId            String    @db.Uuid
  pricePerUnit      Float
  currency          Currency
  category          String?
  unit              Unit      @relation(fields: [unitId], references: [id])
  user              User      @relation(fields: [userId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  recipeIngredients RecipeIngredient[]
}

model Recipe {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  name              String?
  description       String?
  portions          Int       @default(1)
  salePrice         Float
  currency          Currency
  marginPercent     Float     @default(0)
  user              User      @relation(fields: [userId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  ingredients       RecipeIngredient[]
}

model RecipeIngredient {
  id                String      @id @default(uuid()) @db.Uuid
  recipeId          String      @db.Uuid
  ingredientId      String      @db.Uuid
  quantity          Float
  unitId            String      @db.Uuid
  recipe            Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient        Ingredient  @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  unit              Unit        @relation(fields: [unitId], references: [id])
}

model SalesRecord {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @db.Uuid
  date         DateTime         @default(now())
  deliveryFee  Float            @default(0)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items        SalesItem[]
  expenseItems SaleExpenseItem[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([userId, date])
}

model SalesItem {
  id                String      @id @default(uuid()) @db.Uuid
  salesRecordId     String      @db.Uuid
  recipeId          String      @db.Uuid
  quantity          Float
  snapshotSalePrice Float
  snapshotCostPrice Float
  currency          Currency
  recipeName        String?
  salesRecord       SalesRecord @relation(fields: [salesRecordId], references: [id], onDelete: Cascade)

  @@index([salesRecordId])
  @@index([recipeId])
}

model Expense {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  name      String
  amount    Float
  icon      String   @default("package")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExpenseItem {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @db.Uuid
  name         String
  description  String?
  pricePerUnit Float
  unitId       String           @db.Uuid
  currency     Currency
  icon         String           @default("package")
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  unit         Unit             @relation(fields: [unitId], references: [id])
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  saleExpenseItems SaleExpenseItem[]

  @@index([userId])
}

model SaleExpenseItem {
  id             String      @id @default(uuid()) @db.Uuid
  salesRecordId  String      @db.Uuid
  expenseItemId  String      @db.Uuid
  quantity       Float
  snapshotPrice  Float
  currency       Currency
  salesRecord    SalesRecord @relation(fields: [salesRecordId], references: [id], onDelete: Cascade)
  expenseItem    ExpenseItem @relation(fields: [expenseItemId], references: [id], onDelete: Cascade)

  @@index([salesRecordId])
  @@index([expenseItemId])
}
